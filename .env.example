# Copy to .env for local development. Never commit a real .env file.
# Production values are configured directly in Zeabur's environment
# variable UI — this file is documentation + local Docker defaults only.

NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# Local Docker MySQL (see docker-compose.yml). Points at the Zeabur MySQL
# instance only if you deliberately override these for a manual, read-only
# db:verify run — never point DB_* at production for db:migrate.
DB_HOST=localhost
DB_PORT=3306
DB_USER=jinfeng
DB_PASSWORD=local_dev_only
DB_DATABASE=jinfeng_local
DB_CONNECTION_LIMIT=10

# Generate a real random value locally, e.g. `openssl rand -hex 32`.
JWT_SECRET=replace-with-a-long-random-local-dev-only-secret
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

# Comma-separated list of allowed browser origins, e.g. http://localhost:5173
CORS_ALLOWED_ORIGINS=
