# Reference .env.example for the future Node.js project. All values here are PLACEHOLDERS —
# never commit real credentials. Production values live only in Zeabur's environment variable
# configuration (see nodejs/doc/Zeabur環境變數.md for the variable NAMES already used there —
# do not copy actual values from that file either).

NODE_ENV=development
PORT=8080

# --- Database (local docker-compose values match docker-compose.yml above) ---
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_DATABASE=jinfeng_local

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth ---
# Login/auth is being fully reimplemented in the new Node project (AUTH_REIMPLEMENTATION_REQUIRED,
# see known-legacy-issues.md). No Laravel Passport keys/tokens are used or needed. Bcrypt is kept
# only so the new login endpoint can verify existing users' EXISTING password hashes in `users.password`.
JWT_SECRET=change_me
JWT_EXPIRES_IN=1d
BCRYPT_ROUNDS=10

# --- Mail (see known-legacy-issues.md — recipient address is currently hardcoded in the legacy code) ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=change_me
MAIL_PASSWORD=change_me
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=example
RECIPIENT_EMAIL=change_me

# --- CORS (see api-specification.md for the exact whitelist to reproduce) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
