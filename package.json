{
  "name": "jinfeng-back-node",
  "version": "0.1.0",
  "description": "Node.js/TypeScript backend migrated from Laravel 5.6 (jinfeng)",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:verify": "tsx scripts/verify-schema.ts",
    "openapi:validate": "tsx scripts/validate-openapi.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qaz326978547/jinfeng-back-node.git"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/qaz326978547/jinfeng-back-node/issues"
  },
  "homepage": "https://github.com/qaz326978547/jinfeng-back-node#readme",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.23.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "openapi-types": "^12.1.3",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.6",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
